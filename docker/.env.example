# ─── URLs ───────────────────────────────────────────────────────────────────
# The URL the frontend uses to reach the API gateway (local-only)
SUPABASE_URL=http://127.0.0.1:8000

# OAuth callback base URL (local-only by default)
API_EXTERNAL_URL=http://127.0.0.1:8000

# Frontend URL used in auth redirect flows
SITE_URL=http://127.0.0.1:3000

# Additional redirect URLs for OAuth (comma-separated, supports wildcards)
ADDITIONAL_REDIRECT_URLS=http://127.0.0.1/**,http://localhost/**,https://vizionx.pro/**

# ─── Ports ──────────────────────────────────────────────────────────────────
KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443
STUDIO_PORT=8001

# ─── Google OAuth ───────────────────────────────────────────────────────────
ENABLE_GOOGLE_AUTH=true
GOOGLE_CLIENT_ID=364355893158-1r4ijdkam3geq01ib7m0rb0ap936pbjp.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=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

# ─── Apple OAuth ────────────────────────────────────────────────────────────
ENABLE_APPLE_AUTH=false
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# ─── Email / SMTP ──────────────────────────────────────────────────────────
ENABLE_EMAIL_AUTOCONFIRM=true
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_ADMIN_EMAIL=admin@vizionx.pro

# ─── Realtime ───────────────────────────────────────────────────────────────
REALTIME_SECRET_KEY_BASE=ChangeThisToASuperLongSecretForRealtime1234567890

# ─── Logging (optional) ────────────────────────────────────────────────────
LOGFLARE_API_KEY=
