###############################################################################
# VizionX – Docker environment variables
# Copy this file to .env and fill in the values before running docker compose.
###############################################################################

# ─── Postgres ───────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=your-super-secret-postgres-password
POSTGRES_PORT=5432

# ─── JWT (shared by all services) ──────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-token-at-least-32-characters
JWT_EXP=3600

# ─── API Keys (generate with JWT_SECRET using supabase CLI or jwt.io) ─────
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── URLs ───────────────────────────────────────────────────────────────────
# The URL the frontend uses to reach the API gateway
SUPABASE_URL=http://localhost:8000

# The external URL for OAuth callbacks (use your public domain in production)
API_EXTERNAL_URL=http://localhost:8000

# The frontend URL (used by GoTrue for redirect links)
SITE_URL=http://localhost:3000

# Additional redirect URLs for OAuth (comma-separated, supports wildcards)
ADDITIONAL_REDIRECT_URLS=http://localhost:3000/**,https://*.lovable.app/**

# ─── Ports ──────────────────────────────────────────────────────────────────
KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443
STUDIO_PORT=3001

# ─── Google OAuth ───────────────────────────────────────────────────────────
ENABLE_GOOGLE_AUTH=true
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── Apple OAuth ────────────────────────────────────────────────────────────
ENABLE_APPLE_AUTH=false
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# ─── Email / SMTP ──────────────────────────────────────────────────────────
ENABLE_EMAIL_AUTOCONFIRM=true
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_ADMIN_EMAIL=admin@vizionx.pro

# ─── Realtime ───────────────────────────────────────────────────────────────
REALTIME_SECRET_KEY_BASE=ChangeThisToASuperLongSecretForRealtime1234567890

# ─── Logging (optional) ────────────────────────────────────────────────────
LOGFLARE_API_KEY=
